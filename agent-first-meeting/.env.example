# Azure AI Foundry（GPT-4.1 + text-embedding-3-large デプロイ先）
AZURE_OPENAI_ENDPOINT=https://<your-foundry-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure Cosmos DB（顧客・面談・事例 + Vector Search）
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=sales-agent

# Azure Blob Storage（生成 PowerPoint の保存先）
BLOB_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net/
BLOB_CONTAINER=generated-documents
# 開発時はストレージアカウント キーを直接指定（ローカル簡略化）。
# 本番（Container Apps デプロイ時）は空にして Managed Identity を使う：
# その場合は user delegation SAS を発行するため、実行 ID に
# "Storage Blob Data Contributor" 以上のロールが必要。
BLOB_ACCOUNT_KEY=

# 提案資料の「自社商品 / 費用」スライドに入れる値（任意）。
# 未設定なら商品名は汎用プレースホルダ、価格 0 は「別途お見積もり」と表示され、
# 顧客向け資料に偽の金額が出ないようにしている。実値はここで上書きする。
DEFAULT_PRODUCT_NAME=弊社ソリューション
DEFAULT_PRODUCT_PRICE_JPY=0

# アプリ設定
APP_LOG_LEVEL=INFO
# CORS で受け付けるオリジン（カンマ区切り）。本番では Streamlit / フロントの実ドメインに絞ること。
# 開発時のみ "*" で wildcard も可。
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
